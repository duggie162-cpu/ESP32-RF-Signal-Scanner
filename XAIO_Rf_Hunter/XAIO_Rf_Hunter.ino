#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <math.h>

/*
Wiring Guide for RF Signal Scanner:

Power Circuit:
1. Boost Converter A OUT+ (adjusted to 9V) -> AD8317 VCC
2. Boost Converter B OUT+ (adjusted to 5V) -> XAIO VCC In

Signal and Control:
7. AD8317 VOUT -> D0 (GPIO2) - ADC capable
8. Potentiometer VCC -> XAIO 3.3V
9. Potentiometer GND -> XAIO GND
10. Potentiometer Wiper -> D1 (GPIO3) - ADC capable
11. OLED Display VCC -> XAIO 3.3V
12. OLED Display GND -> XAIO GND
13. OLED Display SDA -> D4 (GPIO21)
14. OLED Display SCL -> D5 (GPIO20)
15. Piezo Buzzer positive -> D8 (GPIO8) - digital output
16. Piezo Buzzer negative -> XAIO GND

Notes:
- The power switch controls the main Ground flow from the battery.
- u103 potentiometer pinout 3.3v - D1 - Ground

*/

#define SCREEN_WIDTH 128 // OLED display width, in pixels
#define SCREEN_HEIGHT 64 // OLED display height, in pixels

// Pin definitions for ESP32
#define RF_SENSOR_PIN 2     // D0 (GPIO2) - ADC capable
#define POT_PIN 3           // D1 (GPIO3) - ADC capable
#define OLED_SDA 6         // D4 (GPIO21)
#define OLED_SCL 7         // D5 (GPIO20)
#define BUZZER_PIN 8        // D8 (GPIO8) - digital output

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

